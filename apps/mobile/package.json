{
  "name": "polycode-mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "dependencies": {
    "@polycode/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.4",
    "expo-camera": "~17.0.10",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "^57.0.5",
    "expo-device": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-updates": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "update": "eas update --branch production --auto",
    "apk:dev": "APP_VARIANT=development expo prebuild -p android --no-install && cd android && gradlew assembleDebug",
    "apk:release": "expo prebuild -p android --no-install && cd android && gradlew assembleRelease"
  },
  "private": true
}
