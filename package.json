{
  "name": "polycode",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node apps/desktop/scripts/postinstall.js",
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "start": "bun run --cwd apps/desktop start",
    "start:prod": "bun run --cwd apps/desktop start:prod",
    "test": "bun run --cwd apps/desktop test",
    "dist": "bun run --cwd apps/desktop dist",
    "dist:publish": "bun run --cwd apps/desktop dist:publish",
    "mobile": "bun run --cwd apps/mobile start",
    "mobile:update": "bun run --cwd apps/mobile update"
  },
  "overrides": {
    "vite": "^8.0.0"
  }
}
