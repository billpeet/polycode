{
  "name": "polycode",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": "22.x",
    "pnpm": "11.x"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.23.1",
      "onFail": "download"
    }
  },
  "scripts": {
    "postinstall": "node apps/desktop/scripts/postinstall.js",
    "dev": "pnpm --filter polycode-electron dev",
    "build": "pnpm --filter polycode-electron build",
    "preview": "pnpm --filter polycode-electron preview",
    "start": "pnpm --filter polycode-electron start",
    "start:prod": "pnpm --filter polycode-electron start:prod",
    "test": "pnpm --filter polycode-electron test",
    "dist": "pnpm --filter polycode-electron dist",
    "dist:publish": "pnpm --filter polycode-electron dist:publish",
    "mobile": "pnpm --filter polycode-mobile start",
    "mobile:update": "pnpm --filter polycode-mobile update"
  }
}
